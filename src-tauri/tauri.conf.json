{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OktamaDnsFilter",
  "version": "1.0.0",
  "identifier": "com.oktama.dnsfilter",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Oktama DnsFilter",
        "width": 900,
        "height": 750,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    
    "resources": {
"libs/WinDivert.dll": "WinDivert.dll",
      "libs/WinDivert64.sys": "WinDivert64.sys"
    },

    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": ["Indonesian", "English"]
      }
    }
  }
}